{
  "permissions": {
    "allow": [
      "Bash(git:*)", "Bash(pnpm:*)", "Bash(npm:*)", "Bash(node:*)", "Bash(bun:*)",
      "Bash(python3:*)", "Bash(uv:*)", "Bash(ruff:*)", "Bash(vitest:*)", "Bash(playwright:*)",
      "Bash(ls:*)", "Bash(cat:*)", "Bash(grep:*)", "Bash(find:*)", "Bash(mkdir:*)",
      "Bash(cp:*)", "Bash(mv:*)", "Bash(echo:*)", "Bash(jq:*)", "Bash(curl:*)"
    ],
    "deny": [
      "Bash(rm -rf /*)", "Bash(rm -rf ~*)", "Bash(dd:*)", "Bash(mkfs:*)",
      "Bash(sudo rm:*)", "Bash(chmod 777:*)"
    ],
    "ask": [
      "Bash(sudo:*)", "Bash(rm -rf:*)", "Bash(kill:*)", "Bash(killall:*)",
      "Bash(pkill:*)", "Bash(systemctl:*)", "Bash(shutdown:*)", "Bash(reboot:*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "ccstatusline",
    "timeout": 3000
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "bun construct/memory/hooks/session-start.ts", "timeout": 5000 }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "bun construct/memory/hooks/rating-capture.ts", "timeout": 2000 }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "bun construct/skills/hooks/format-reminder.ts", "timeout": 3000 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "bun construct/memory/hooks/memory-gate.ts", "timeout": 5000 }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "bun construct/memory/hooks/session-summary.ts", "timeout": 3000 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "bun construct/skills/hooks/quality.ts", "timeout": 10000 }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          { "type": "command", "command": "bun construct/skills/hooks/notify.ts", "timeout": 3000 }
        ]
      }
    ]
  }
}
