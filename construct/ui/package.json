{
  "name": "construct-ui",
  "private": true,
  "workspaces": [
    "api",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"bun --watch api/src/server.ts\" \"cd web && bun run dev\"",
    "build": "cd web && bun run build",
    "test:e2e": "bun e2e/goal-flow.test.ts",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@construct/data": "file:../data",
    "@construct/goals": "file:../goals"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "playwright": "^1.58.2",
    "typescript": "^5.7.3"
  }
}
