# Copy to .env at the repo root and fill in. .env is gitignored.
# See README "Environment variables" for the full list and defaults.

# Research engine — at least one LLM key is required to run workers.
OPENROUTER_API_KEY=        # required for research workers
ANTHROPIC_API_KEY=         # optional fallback

# Research search providers (optional — enable the ones you have).
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
JINA_API_KEY=
