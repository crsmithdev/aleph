{
  "statusLine": {
    "type": "command",
    "command": "ccstatusline",
    "timeout": 3000
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun src/memory/hooks/context-restore-start.ts 2>/dev/null",
            "timeout": 5000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun src/memory/hooks/rating-capture-submit.ts 2>/dev/null",
            "timeout": 2000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun src/core/hooks/routing-classify-submit.ts 2>/dev/null",
            "timeout": 3000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun src/core/hooks/quality-check-stop.ts 2>/dev/null",
            "timeout": 3000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun src/core/hooks/context-monitor-stop.ts 2>/dev/null",
            "timeout": 3000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun src/memory/hooks/context-save-stop.ts 2>/dev/null",
            "timeout": 3000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun src/memory/hooks/memory-extract-stop.ts 2>/dev/null",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__.*(?:execute_sql|apply_migration|run_query)",
        "hooks": [
          {
            "type": "command",
            "command": "bun src/core/hooks/isolation-block-sql.ts 2>/dev/null",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun src/core/hooks/git-require-edit.ts 2>/dev/null",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun src/core/hooks/context-suggest-edit.ts 2>/dev/null",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun src/core/hooks/security-scan-bash.ts 2>/dev/null",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun src/core/hooks/quality-format-edit.ts 2>/dev/null",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun src/core/hooks/quality-typecheck-edit.ts 2>/dev/null",
            "timeout": 15000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun src/core/hooks/context-backup-precompact.ts 2>/dev/null",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
