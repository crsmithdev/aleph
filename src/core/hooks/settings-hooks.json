{
  "statusLine": {
    "type": "command",
    "command": "ccstatusline",
    "timeout": 3000
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun src/memory/hooks/session-start.ts",
            "timeout": 5000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun src/memory/hooks/rating-capture.ts",
            "timeout": 2000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun src/skills/hooks/routing-submit-classify.ts",
            "timeout": 3000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun src/skills/hooks/quality-stop-check-e2e.ts",
            "timeout": 3000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun src/skills/hooks/context-stop-monitor.ts",
            "timeout": 3000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun src/memory/hooks/session-summary.ts",
            "timeout": 3000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun src/memory/hooks/memory-extract.ts",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__.*(?:execute_sql|apply_migration|run_query)",
        "hooks": [
          {
            "type": "command",
            "command": "bun src/skills/hooks/isolation-pre-block-destructive-sql.ts",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun src/skills/hooks/git-pre-require-commit.ts",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun src/skills/hooks/quality-pre-require-e2e.ts",
            "timeout": 2000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun src/skills/hooks/quality-post-format.ts",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun src/skills/hooks/quality-post-typecheck.ts",
            "timeout": 15000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun src/skills/hooks/context-precompact-backup.ts",
            "timeout": 5000
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun src/skills/hooks/notify-event-toast.ts",
            "timeout": 3000
          }
        ]
      }
    ]
  }
}
