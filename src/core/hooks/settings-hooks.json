{
  "statusLine": {
    "type": "command",
    "command": "ccstatusline",
    "timeout": 3000
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun src/memory/hooks/session-start.ts 2>/dev/null",
            "timeout": 5000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun src/memory/hooks/rating-capture.ts 2>/dev/null",
            "timeout": 2000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun src/core/hooks/routing-submit-classify.ts 2>/dev/null",
            "timeout": 3000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun src/core/hooks/quality-stop-check-e2e.ts 2>/dev/null",
            "timeout": 3000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun src/core/hooks/context-stop-monitor.ts 2>/dev/null",
            "timeout": 3000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun src/memory/hooks/session-summary.ts 2>/dev/null",
            "timeout": 3000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun src/memory/hooks/memory-extract.ts 2>/dev/null",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__.*(?:execute_sql|apply_migration|run_query)",
        "hooks": [
          {
            "type": "command",
            "command": "bun src/core/hooks/isolation-pre-block-destructive-sql.ts 2>/dev/null",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun src/core/hooks/git-pre-require-commit.ts 2>/dev/null",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun src/core/hooks/quality-post-format.ts 2>/dev/null",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun src/core/hooks/quality-post-typecheck.ts 2>/dev/null",
            "timeout": 15000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun src/core/hooks/context-precompact-backup.ts 2>/dev/null",
            "timeout": 5000
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun src/core/hooks/notify-event-toast.ts 2>/dev/null",
            "timeout": 3000
          }
        ]
      }
    ]
  }
}
